# ── Google Service Account ────────────────────────────────────
# Option A: JSON string (ideal for containers / CI)
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Option B: path to service account JSON file
# GOOGLE_CREDENTIALS_FILE=/path/to/service-account.json

# ── Site ──────────────────────────────────────────────────────
SITE_URL=sc-domain:example.com

# ── Proxy (optional) ─────────────────────────────────────────
# Route all Google API requests through a proxy
# PROXY_URL=http://user:pass@<VPS-IP>:3128

# ── Token cache ──────────────────────────────────────────────
# GOOGLE_ACCESS_TOKEN_TTL_SECONDS=3300
