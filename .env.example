# ── Credentials ──────────────────────────────────────────────
# Option A: JSON string via env var (takes precedence, ideal for containers)
# GOOGLE_CREDENTIALS_BOOSTVISION={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","private_key_id":"..."}
# GOOGLE_CREDENTIALS_PIGEONCAST=
# GOOGLE_CREDENTIALS_FIRSTORDER=
# GOOGLE_CREDENTIALS_CUBESOLVER=

# Option B: file-based — directory containing {brand}/gsc.json
CREDENTIALS_DIR=/path/to/credentials

# Default brand (optional — tools will use this if brand param is omitted)
GSC_DEFAULT_BRAND=boostvision

# Per-brand site URLs (optional — tools will use this if site_url param is omitted)
SITE_URL_BOOSTVISION=sc-domain:boostvision.tv
# SITE_URL_PIGEONCAST=sc-domain:pigeoncast.com
# SITE_URL_FIRSTORDER=sc-domain:firstorder.ai
# SITE_URL_CUBESOLVER=sc-domain:cubesolver.ai

# Per-brand VPS proxy endpoints (only configure brands you need)
PROXY_BOOSTVISION=http://user:pass@<VPS-IP>:3128
# PROXY_PIGEONCAST=http://user:pass@<VPS-IP>:3128
# PROXY_FIRSTORDER=http://user:pass@<VPS-IP>:3128
# PROXY_CUBESOLVER=http://user:pass@<VPS-IP>:3128

# Token cache TTL (seconds, default 3300 = 55 min)
# GOOGLE_ACCESS_TOKEN_TTL_SECONDS=3300
